{
  "version": 2,
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/api/auth/(register|register-otp|verify-email|login|login-email-phone|checkout-guest|logout|login-otp|me|request-otp|verify-otp|course-register|check-phone|request-phone-change|verify-phone-change|confirm-phone-change|line)/(.*)",
        "destination": "/server/index.js"
      },
      {
        "source": "/api/auth/(register|register-otp|verify-email|login|login-email-phone|checkout-guest|logout|login-otp|me|request-otp|verify-otp|course-register|check-phone|request-phone-change|verify-phone-change|confirm-phone-change|line)",
        "destination": "/server/index.js"
      }
    ],
    "afterFiles": [
      {
        "source": "/api/(courses|imports|admin|user|shop|shipping)/(.*)",
        "destination": "/server/index.js"
      },
      {
        "source": "/api/(courses|imports|admin|user|shop|shipping)",
        "destination": "/server/index.js"
      },
      {
        "source": "/(.*)",
        "destination": "/web/$1"
      }
    ]
  }
}
