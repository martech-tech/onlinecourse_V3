PORT=4000
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=onlinecourse
CORS_ORIGIN=http://localhost:3000

# OTP (ThaiBulkSMS)
OTP_KEY=""
OTP_SECRET=""

# Local dev fallback (จะตอบ devOtpCode กลับมา ใช้เฉพาะตอนทดสอบ)
OTP_DEV_MODE=true
OTP_DEV_CODE=

# OTP authorize cookie (สำหรับอนุญาต Step 2)
OTP_COOKIE_NAME=
OTP_PURPOSE=
OTP_JWT_EXPIRES_IN=15m
OTP_COOKIE_MAX_AGE_SECONDS=900

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=30d 
JWT_COOKIE_MAX_AGE_SECONDS=2592000

# Web app base URL (used to build reset link)
WEB_APP_URL=http://localhost:3000

# SMTP (DirectAdmin / mail server)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=""
SMTP_TLS_REJECT_UNAUTHORIZED=1
# SMTP_TLS_REJECT_UNAUTHORIZED=1 For production use, set to 0 ONLY for testing if the mail server has an expired/self-signed cert.

# Cookie name (optional)
AUTH_COOKIE_NAME=

# Cookie domain (optional). Set this in production if API and Web are on different subdomains.
# Example: COOKIE_DOMAIN=
COOKIE_DOMAIN=

# LINE Login (https://developers.line.biz/console/)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CALLBACK_URL=http://localhost:4000/auth/line/callback

# J&T Express Thailand - API Configuration
JT_API_ACCOUNT=
JT_API_KEY=
JT_CUSTOMER_CODE=
JT_EXPRESS_TYPE=

# J&T Endpoint URLs (Demo / Sandbox)
JT_URL_CREATE_ORDER=https://demoopenapi.jtexpress.co.th/webopenplatformapi/api/order/addOrder?uuid=
JT_URL_CANCEL_ORDER=https://demoopenapi.jtexpress.co.th/webopenplatformapi/api/order/cancelOrder?uuid=
JT_URL_TRACKING_QUERY=https://demoopenapi.jtexpress.co.th/webopenplatformapi/api/logistics/trace?uuid=

# Default sender / warehouse address
JT_SENDER_NAME=JKnowledge Shop
JT_SENDER_PHONE=0812345678
JT_SENDER_PROVINCE=
JT_SENDER_CITY=
JT_SENDER_DISTRICT=
JT_SENDER_ADDRESS=
JT_SENDER_POST_CODE=
