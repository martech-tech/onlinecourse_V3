# --------------------------------------------------------------------------
# ฐานข้อมูล PostgreSQL จาก Supabase 
# --------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# --------------------------------------------------------------------------
# เส้นทางสำหรับเชื่อมต่อหน้าเว็บและหลังบ้าน 
# --------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL="/api"
CORS_ORIGIN="https://[ชื่อโดเมน Vercel ของคุณ].vercel.app"
WEB_APP_URL="https://[ชื่อโดเมน Vercel ของคุณ].vercel.app"

# --------------------------------------------------------------------------
# ข้อมูลเก่าจาก .env_old.local สำหรับ Next.js Auth และ PaySolutions
# --------------------------------------------------------------------------
NEXTAUTH_SECRET="ใส่รหัสผ่านมั่วๆเพื่อความปลอดภัยของเว็บยาวๆ1ชุด"
NEXTAUTH_URL="https://[ชื่อโดเมน Vercel ของคุณ].vercel.app"
NEXT_DISABLE_TURBOPACK="1"
NEXT_PUBLIC_PAYSOLUTIONS_DEV_MODE="true"

# --------------------------------------------------------------------------
# รหัสความปลอดภัยใช้เข้ารหัส 
# --------------------------------------------------------------------------
JWT_SECRET="mySecretKey2026OnlineCourseV3SuperSecret123456"

